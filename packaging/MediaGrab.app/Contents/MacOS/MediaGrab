#!/bin/bash
# MediaGrab Launcher — bundled .app version
# Uses portable Node.js + bundled binaries; no Homebrew or Python required.

set -e

# Resolve the .app bundle's Resources directory
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
APP_ROOT="$(dirname "$SCRIPT_DIR")"
RESOURCES="$APP_ROOT/Resources"

NODE_BIN="$RESOURCES/node/bin/node"
APP_DIR="$RESOURCES/app"
VENDOR_BIN="$RESOURCES/bin"

# Per-user data location (writable; the .app itself lives in /Applications and is read-only)
USER_DATA="$HOME/Library/Application Support/MediaGrab"
mkdir -p "$USER_DATA"
LOG_FILE="$USER_DATA/server.log"

# Make bundled binaries discoverable to child processes (spawned yt-dlp, ffmpeg)
export PATH="$VENDOR_BIN:/opt/homebrew/bin:/usr/local/bin:$PATH"

# Point Playwright to bundled browser
export PLAYWRIGHT_BROWSERS_PATH="$RESOURCES/ms-playwright"

export NODE_ENV=production
PORT=${PORT:-9800}
export PORT

# Version of THIS bundle (used to decide reuse vs. update-takeover)
MY_VERSION="$(sed -n 's/.*"version": *"\([^"]*\)".*/\1/p' "$APP_DIR/package.json" 2>/dev/null | head -1)"

# If an instance is already holding the port:
if lsof -ti tcp:$PORT >/dev/null 2>&1; then
  RUNNING_VERSION="$(curl -s "http://localhost:$PORT/api/status" 2>/dev/null | sed -n 's/.*"version":"\([^"]*\)".*/\1/p' | head -1)"
  if [ -n "$MY_VERSION" ] && [ "$RUNNING_VERSION" = "$MY_VERSION" ]; then
    # Same version already running — just open the browser to it.
    open "http://localhost:$PORT"
    exit 0
  fi
  # An older/unknown instance holds the port (e.g. you just updated) — ask it to
  # quit, then wait for the port to free so this version can take over.
  curl -s -X POST "http://localhost:$PORT/api/quit" >/dev/null 2>&1 || true
  for i in $(seq 1 30); do
    lsof -ti tcp:$PORT >/dev/null 2>&1 || break
    sleep 0.3
  done
  # Last resort (e.g. an old build with no /api/quit still holding the port):
  # force-stop whatever holds the port so the update can take over.
  if lsof -ti tcp:$PORT >/dev/null 2>&1; then
    lsof -ti tcp:$PORT | xargs kill 2>/dev/null || true
    for i in $(seq 1 20); do
      lsof -ti tcp:$PORT >/dev/null 2>&1 || break
      sleep 0.3
    done
  fi
fi

# Start the server, with logs going to ~/Library/Application Support/MediaGrab/server.log
cd "$APP_DIR"
"$NODE_BIN" server/index.js >>"$LOG_FILE" 2>&1 &
SERVER_PID=$!
echo $SERVER_PID > "$USER_DATA/server.pid"

# Wait until the server responds (up to ~15 seconds), then open browser
for i in $(seq 1 30); do
  if curl -s -o /dev/null -w "%{http_code}" "http://localhost:$PORT/api/status" 2>/dev/null | grep -q "200"; then
    open "http://localhost:$PORT"
    exit 0
  fi
  sleep 0.5
done

# Fallback: open anyway
open "http://localhost:$PORT"

# Show a friendly alert if the server didn't come up
if ! curl -s -o /dev/null "http://localhost:$PORT/api/status" 2>/dev/null; then
  osascript -e 'display alert "MediaGrab" message "啟動失敗，請查看 ~/Library/Application Support/MediaGrab/server.log" as critical' 2>/dev/null
fi
