{
  "manifest_version": 3,
  "name": "MediaGrab Companion",
  "version": "0.2.2",
  "description": "Capture login-gated / streaming course video from the page you're on (HLS/DASH on any CDN, hidden manifests, MSE) and hand it to the MediaGrab app to download.",
  "key": "",
  "permissions": ["webRequest", "storage", "nativeMessaging", "activeTab", "scripting"],
  "optional_host_permissions": ["<all_urls>"],
  "background": { "service_worker": "background.js" },
  "action": {
    "default_popup": "popup.html",
    "default_title": "MediaGrab Companion"
  }
}
